{
  "permissions": {
    "allow": [
      "Bash(git push origin *)",
      "Bash(gh pr create*)"
    ],
    "deny": [
      "Bash(git push*main*)",
      "Bash(git push*--delete*)",
      "Bash(git push* :*)",
      "Bash(git push*--force*)",
      "Bash(git push*-f *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets.json)",
      "Read(**/credentials.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/Library/Keychains/**)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(env)",
      "Bash(printenv)",
      "Bash(cat ~/.ssh/*)",
      "Bash(cat ~/.zsh_history*)",
      "Bash(cat ~/.bash_history*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "failIfUnavailable": false,
    "excludedCommands": [
      "gh pr create*",
      "gh pr view*",
      "gh pr list*",
      "gh auth status*",
      "git push origin*"
    ],
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": [
        "pypi.org",
        "files.pythonhosted.org",
        "github.com",
        "*.github.com",
        "api.github.com",
        "codeload.github.com",
        "objects.githubusercontent.com",
        "localhost",
        "127.0.0.1"
      ]
    },
    "filesystem": {
      "allowWrite": ["."],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.config/gcloud",
        "~/Library/Keychains",
        "~/.secrets"
      ]
    }
  }
}
