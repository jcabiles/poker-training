# Expose the `poker-trainer` command on PATH the moment direnv is allowed.
# Kept FIRST so it works even on a fresh clone, before the backend venv exists.
PATH_add bin

# Auto-activate the backend venv once it's been created (see README setup).
# Guarded so a fresh clone without a venv doesn't error before PATH_add runs.
[ -f backend/.venv/bin/activate ] && source backend/.venv/bin/activate
